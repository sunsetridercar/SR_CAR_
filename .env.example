# ────────────────────────────────────────────────────────────────
# Variables d'environnement — TinaCloud (https://app.tina.io)
# Un projet TinaCloud isolé PAR CLIENT. Copier ce fichier en .env
# (local) et saisir les mêmes valeurs dans Vercel (Project Settings).
# ────────────────────────────────────────────────────────────────

# ID public du projet TinaCloud (Project → Overview).
NEXT_PUBLIC_TINA_CLIENT_ID=

# Jeton de lecture/écriture TinaCloud (Project → Tokens). SECRET — ne jamais commiter.
TINA_TOKEN=

# Branche Git suivie par TinaCloud et éditée depuis /admin (ex. main).
NEXT_PUBLIC_TINA_BRANCH=main
